APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8008
PUBLIC_BASE_URL=https://your-domain.example.com

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner

# WeCom self-built app
WE_COM_CORP_ID=wwxxxxxxxxxxxxxxxx
WE_COM_AGENT_ID=1000002
WE_COM_SECRET=your-agent-secret
WE_COM_TOKEN=your-callback-token
WE_COM_ENCODING_AES_KEY=your-43-char-encoding-aes-key
OWNER_WE_COM_USER_ID=your-wecom-user-id

# Storage
POSTGRES_PASSWORD=assistant
DATABASE_URL=postgresql+asyncpg://assistant:assistant@postgres:5432/wecom_assistant
REDIS_URL=redis://redis:6379/0
APP_ENCRYPTION_KEY=replace-with-a-long-random-secret

# Optional self-hosted search. Keep enabled; failures degrade gracefully.
SEARXNG_BASE_URL=http://searxng:8080
SEARCH_ENABLED=true

# App behavior
AUTO_CREATE_TABLES=true
DEBUG_ROUTES_ENABLED=false
DAILY_SUMMARY_HOUR=22
WEEKLY_MEMORY_REVIEW_DAY=sun
WEEKLY_MEMORY_REVIEW_HOUR=21
MEMORY_RETRIEVAL_LIMIT=12
MEMORY_CONTEXT_CHAR_BUDGET=1600
MEMORY_ITEM_CHAR_LIMIT=120
RECENT_MESSAGE_LIMIT=8
